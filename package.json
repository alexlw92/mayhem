{
  "name": "mayhem",
  "version": "1.0.2",
  "description": "ARAM Mayhem stats tracker",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "test": "vitest run",
    "server:build": "tsc --project tsconfig.server.json",
    "server:start": "node dist-server/server-entry.js",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.mayhem.stats",
    "productName": "Mayhem Stats",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "resources/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "alexlw92",
      "repo": "mayhem"
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "postgres": "^3.4.9",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^36.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^4.1.10"
  }
}
