{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-worker"
  },
  "include": [
    "src/worker/**/*",
    "src/main/lcu.ts",
    "src/main/sync.ts",
    "src/main/apiClient.ts",
    "src/main/config.ts",
    "src/backend/**/*"
  ],
  "exclude": ["src/backend/__tests__/**/*", "node_modules"]
}
